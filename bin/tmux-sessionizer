#!/bin/bash
# Fuzzy-pick a project directory and jump to (or create) a tmux session for
# it. Bound to a popup in tmux.conf. Add more roots to SEARCH_DIRS as needed.
set -euo pipefail

SEARCH_DIRS=("$HOME/projects")
EXTRA_ENTRIES=("$HOME/dotfiles")

if [[ $# -eq 1 ]]; then
  selected=$1
else
  selected=$(
    {
      find "${SEARCH_DIRS[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null
      printf '%s\n' "${EXTRA_ENTRIES[@]}"
    } | fzf
  )
fi

[[ -z "${selected:-}" ]] && exit 0

selected_name=$(basename "$selected" | tr ' .' '__')

if ! tmux has-session -t "$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected"
fi

if [[ -z "${TMUX:-}" ]]; then
  tmux attach-session -t "$selected_name"
else
  tmux switch-client -t "$selected_name"
fi
